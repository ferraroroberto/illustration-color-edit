{
  "paths": {
    "input_dir": "./input",
    "output_dir": "./output",
    "metadata_dir": "./metadata"
  },
  "png_export": {
    "enabled": true,
    "dpi": 300,
    "inkscape_path": "inkscape"
  },
  "cmyk_export": {
    "enabled": true,
    "output_dir": "./output_cmyk",
    "icc_profile_path": "./profiles/ISOcoated_v2_eci.icc",
    "ghostscript_path": "gswin64c",
    "target_width_inches": 5.5,
    "target_height_inches": 7.5,
    "bleed_inches": 0.0,
    "pdfx_compliance": false,
    "generate_preview_png": true,
    "preview_dpi": 150,
    "audit_artifacts": true,
    "filename_template": "",
    "tac_limit_percent": 320.0,
    "tac_check_dpi": 100,
    "force_k_min_stroke_pt": 0.5,
    "force_k_min_text_pt": 9.0,
    "safety_inches": 0.1875,
    "show_guide_overlay": true,
    "trim_to_content": {
      "enabled": false,
      "padding_pt": 0.0
    },
    "subdirs": {
      "print": "print",
      "preview": "preview"
    },
    "generate_full_preview": true,
    "render_check": true,
    "render_check_dpi": 300
  }
}
