    "input_dir": "./input",
    "output_dir": "./output",
    "metadata_dir": "./metadata"
  },
  "png_export": {
    "enabled": true,
    "dpi": 300,
    "inkscape_path": "inkscape"
  },
  "cmyk_export": {
    "enabled": true,
    "output_dir": "./output_cmyk",
